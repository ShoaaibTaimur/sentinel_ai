{
  "name": "sentinel-ai",
  "version": "1.0.4",
  "description": "Keyboard-first, system-wide AI assistant for desktop OS",
  "author": "Shoaib Taimur <contact@taimur.dev>",
  "homepage": "https://sentinel.taimur.dev",
  "main": "out/main/index.js",
  "bin": {
    "sentinelai": "./bin/sentinel.js"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron .",
    "package": "electron-vite build && electron-builder"
  },
  "build": {
    "appId": "ai.sentinel",
    "productName": "Sentinel AI",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "mac": {
      "icon": "resources/icon.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "resources/icon.png",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "dependencies": {
    "active-win": "^8.1.0",
    "electron-store": "^8.2.0",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.6",
    "openai": "^4.67.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-ts": "^2.0.0",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.0"
  }
}
